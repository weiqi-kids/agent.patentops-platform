# PatentOps Platform Environment Configuration

# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://patentops:password@localhost:5432/patentops
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis (for BullMQ job queues and caching)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h

# AI Sidecar Service
AI_SERVICE_URL=http://localhost:3100
AI_SERVICE_API_KEY=

# Deadline Engine
DEADLINE_CHECK_INTERVAL_MINUTES=30
DEADLINE_WARNING_DAYS=30,14,7,3,1

# Document Generation
TEMPLATE_DIR=./templates
OUTPUT_DIR=./generated

# External Integrations (future)
# USPTO_API_KEY=
# EPO_OPS_CONSUMER_KEY=
# EPO_OPS_CONSUMER_SECRET=
